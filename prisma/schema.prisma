// Data model for karltoffel_crm — derived from docs/fenster-blueprint/MASTER-BLUEPRINT.md.
// Local dev runs on SQLite (zero-server); production would switch `provider` to
// postgresql + a hosted DATABASE_URL. All scalar types are chosen to be portable
// across both (no enums, no Json — status/tier are plain strings, settings is text).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Company {
  id            Int       @id @default(autoincrement())
  name          String
  cvr           String?
  phone         String?
  email         String?
  planTier      String    @default("Pro") // Free | Pro | Premium
  hourlyPrice   Int       @default(600)   // DKK incl. VAT, excl. driving
  users         User[]
  contacts      Contact[]
  standardTasks StandardTask[]
  settings      String?   // JSON blob (SQLite has no native Json)
  createdAt     DateTime  @default(now())
}

model User {
  id               Int      @id @default(autoincrement())
  company          Company  @relation(fields: [companyId], references: [id])
  companyId        Int
  username         String   @unique
  firstName        String
  lastName         String
  email            String?
  calendarColor    String?  // hex
  activeCalendar   Boolean  @default(true)
  canReceiveOnline Boolean  @default(false)
  homeAddress      String?
  isAdmin          Boolean  @default(false)
  canSeePrices     Boolean  @default(true)
  canEditOrders    Boolean  @default(true)
  canHandlePayment Boolean  @default(true)
  canChangePaymentOption Boolean @default(true)
  orders           Order[]
}

model Contact {
  id            Int       @id @default(autoincrement())
  company       Company   @relation(fields: [companyId], references: [id])
  companyId     Int
  isCompany     Boolean   @default(false)
  companyName   String?
  cvr           String?
  ean           String?
  name          String
  email         String?
  phone         String?
  street        String    // "Ørnedvej 4"
  city          String    // "8660 Skanderborg" (postal + city)
  att           String?   // attention / contact person
  note          String?   // internal address remark
  // display figures shown on the customer list (seeded for parity; recomputed later)
  revenueYtd         Int?  // "Omsætning ÅTD"; null renders as "-"
  avgYearlyFromSubs  Int   @default(0) // "Gns. oms/år fra abo."
  // per-contact invoice overrides
  skipDeliveryAddressOnInvoice Boolean @default(false)
  showDeliveryNameOnInvoice    Boolean @default(false)
  skipInvoiceOverSms           Boolean @default(false)
  invoiceChoicePreselect       String  @default("default")
  subscriptions Subscription[]
  fixedPrices   FixedPriceAgreement[]
  orders        Order[]
  createdAt     DateTime  @default(now())
}

model StandardTask {
  id          Int      @id @default(autoincrement())
  company     Company  @relation(fields: [companyId], references: [id])
  companyId   Int
  category    String
  description String
  letter      String?
  customerPresenceRequired Boolean @default(false)
  isSystem    Boolean  @default(false) // locked, cannot edit/deactivate
  active      Boolean  @default(true)
}

model TaskLine {
  id            Int      @id @default(autoincrement())
  category      String
  letter        String
  color         String   // category hex (denormalised for the formset)
  description   String
  price         Int      // incl. VAT (kr)
  durationMin   Int
  customerPresenceRequired Boolean @default(false)
  isStandardTask     Boolean @default(false)
  fromSubscription   Boolean @default(false)
  intervalMultiplier String?  // subscriptions/orders only — "Hver 2. gang (hver 4. uge)"
  startWeek     String?        // subscriptions only — "Uge 29"
  subscription  Subscription? @relation(fields: [subscriptionId], references: [id])
  subscriptionId Int?
  fixedPrice    FixedPriceAgreement? @relation(fields: [fixedPriceId], references: [id])
  fixedPriceId  Int?
  order         Order?   @relation(fields: [orderId], references: [id])
  orderId       Int?
  sort          Int      @default(0)
}

model Subscription {
  id             Int       @id @default(autoincrement()) // internal URL pk
  displayNo      Int       @unique // "Abo. nr." shown in lists (≠ id/pk)
  contact        Contact   @relation(fields: [contactId], references: [id])
  contactId      Int
  deliveryAddress String
  baseInterval   String    // "Hver 2. uge"
  startWeek      String?
  nextWeek       String?   // "Fremtidige ordrer" label, e.g. "Uge 29"
  fixedWeekdays  String?   // digit string e.g. "1234560"
  fixedTimeOfDay String?
  fixedEmployee  String    @default("Ingen")
  notiOverride   Boolean   @default(false)
  active         Boolean   @default(true)
  tasks          TaskLine[]
  orders         Order[]
  createdAt      DateTime  @default(now())
}

model FixedPriceAgreement {
  id             Int       @id @default(autoincrement())
  displayNo      Int       @unique
  contact        Contact   @relation(fields: [contactId], references: [id])
  contactId      Int
  deliveryAddress String
  tasks          TaskLine[]
  orders         Order[]
}

model Order {
  id            Int       @id @default(autoincrement())
  contact       Contact   @relation(fields: [contactId], references: [id])
  contactId     Int
  deliveryAddress String
  plannedAt     DateTime
  status        String    @default("Afventer levering")
  sourceType    String    // subscription | fixed | manual | online
  subscription  Subscription? @relation(fields: [subscriptionId], references: [id])
  subscriptionId Int?
  fixedPrice    FixedPriceAgreement? @relation(fields: [fixedPriceId], references: [id])
  fixedPriceId  Int?
  employee      User?     @relation(fields: [employeeId], references: [id])
  employeeId    Int?
  lockedFully   Boolean   @default(false)
  comment       String?
  addressNote   String?
  tasks         TaskLine[]
  createdAt     DateTime  @default(now())
}

model DiscountCode {
  id         Int      @id @default(autoincrement())
  code       String
  percent    Int
  expiresAt  DateTime?
}

model HolidayWeek {
  id         Int      @id @default(autoincrement())
  startWeek  DateTime // Monday ISO date
  endWeek    DateTime
}
