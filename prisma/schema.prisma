// Data model for karltoffel_crm — derived from docs/fenster-blueprint/MASTER-BLUEPRINT.md.
// Local dev runs on SQLite (zero-server); production would switch `provider` to
// postgresql + a hosted DATABASE_URL. All scalar types are chosen to be portable
// across both (no enums, no Json — status/tier are plain strings, settings is text).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")  // pooled (-pooler) — app runtime
  directUrl = env("DIRECT_URL")    // direct — migrations
}

model Company {
  id            Int       @id @default(autoincrement())
  name          String
  cvr           String?
  phone         String?
  email         String?
  planTier      String    @default("Pro") // Free | Pro | Premium
  hourlyPrice   Int       @default(600)   // DKK incl. VAT, excl. driving
  minutePriceOere Int     @default(860)   // øre pr. minut EKSKL. moms (8,60 kr/min) — prisberegner: varighed = (pris inkl. moms / 1,25) / (minutePriceOere/100)
  users         User[]
  contacts      Contact[]
  standardTasks StandardTask[]
  leads         Lead[]
  settings      String?   // JSON blob (SQLite has no native Json)
  dineroConnection DineroConnection?
  createdAt     DateTime  @default(now())
}

model User {
  id               Int      @id @default(autoincrement())
  company          Company  @relation(fields: [companyId], references: [id])
  companyId        Int
  username         String   @unique
  passwordHash     String?  // scrypt "salt:hash"; null = cannot log in
  firstName        String
  lastName         String
  email            String?
  calendarColor    String?  // hex
  activeCalendar   Boolean  @default(true)
  canReceiveOnline Boolean  @default(false)
  homeAddress      String?
  active           Boolean  @default(true)   // soft-delete: false = deaktiveret (kan ikke logge ind, skjult i vælgere)
  isAdmin          Boolean  @default(false)
  canSeePrices     Boolean  @default(true)
  canEditOrders    Boolean  @default(true)
  canHandlePayment Boolean  @default(true)
  canChangePaymentOption Boolean @default(true)
  payModel         String   @default("fast")  // lønmodel: "fast" | "akkord"
  commissionPct    Int?     // akkord: provisionssats i % (fx 40)
  monthlySalary    Int?     // fast løn: manuelt beløb (kr/md)
  orders           Order[]
  timeEntries      TimeEntry[]

  @@index([companyId])
}

model Contact {
  id            Int       @id @default(autoincrement())
  company       Company   @relation(fields: [companyId], references: [id])
  companyId     Int
  isCompany     Boolean   @default(false)
  companyName   String?
  cvr           String?
  ean           String?
  name          String
  email         String?
  phone         String?
  street        String    // "Ørnedvej 4"
  city          String    // "8660 Skanderborg" (postal + city)
  att           String?   // attention / contact person
  note          String?   // internal address remark
  // display figures shown on the customer list (seeded for parity; recomputed later)
  revenueYtd         Int?  // "Omsætning ÅTD"; null renders as "-"
  avgYearlyFromSubs  Int   @default(0) // "Gns. oms/år fra abo."
  // per-contact invoice overrides
  skipDeliveryAddressOnInvoice Boolean @default(false)
  showDeliveryNameOnInvoice    Boolean @default(false)
  skipInvoiceOverSms           Boolean @default(false)
  invoiceChoicePreselect       String  @default("default")
  // Dinero (Visma) kontakt-guid — sættes ved første fakturering af kunden, så
  // efterfølgende ordrer kan springe opslag/oprettelse over. @unique er et værn
  // mod at oprette den samme kontakt to gange i Dinero.
  dineroContactGuid            String? @unique
  subscriptions Subscription[]
  fixedPrices   FixedPriceAgreement[]
  orders        Order[]
  leads         Lead[]
  createdAt     DateTime  @default(now())

  @@index([companyId])
}

model StandardTask {
  id          Int      @id @default(autoincrement())
  company     Company  @relation(fields: [companyId], references: [id])
  companyId   Int
  category    String
  description String
  letter      String?
  customerPresenceRequired Boolean @default(false)
  isSystem    Boolean  @default(false) // locked, cannot edit/deactivate
  active      Boolean  @default(true)

  @@index([companyId])
}

model TaskLine {
  id            Int      @id @default(autoincrement())
  category      String
  letter        String
  color         String   // category hex (denormalised for the formset)
  description   String
  price         Int      // incl. VAT (kr)
  durationMin   Int
  customerPresenceRequired Boolean @default(false)
  isStandardTask     Boolean @default(false)
  fromSubscription   Boolean @default(false)
  intervalMultiplier String?  // subscriptions/orders only — "Hver 2. gang (hver 4. uge)"
  startWeek     String?        // subscriptions only — "Uge 29"
  pauseActive   Boolean  @default(false) // "Måneder på pause": opgaven genereres ikke i vinduet
  pauseStart    String?        // ISO 'YYYY-MM-DD' (subscriptions only; window may wrap New Year)
  pauseEnd      String?        // ISO 'YYYY-MM-DD'
  pauseYearly   Boolean  @default(true)  // true = gentag hvert år (kun måned/dag); false = kun denne sæson (absolutte datoer)
  subscription  Subscription? @relation(fields: [subscriptionId], references: [id])
  subscriptionId Int?
  fixedPrice    FixedPriceAgreement? @relation(fields: [fixedPriceId], references: [id])
  fixedPriceId  Int?
  order         Order?   @relation(fields: [orderId], references: [id])
  orderId       Int?
  sort          Int      @default(0)

  @@index([orderId])
  @@index([subscriptionId])
  @@index([fixedPriceId])
}

model Subscription {
  id             Int       @id @default(autoincrement()) // internal URL pk
  displayNo      Int       @unique // "Abo. nr." shown in lists (≠ id/pk)
  contact        Contact   @relation(fields: [contactId], references: [id])
  contactId      Int
  deliveryAddress String
  baseInterval   String    // "Hver 2. uge"
  startWeek      String?
  nextWeek       String?   // "Fremtidige ordrer" label, e.g. "Uge 29"
  fixedWeekdays  String?   // digit string e.g. "1234560"
  fixedTimeOfDay String?
  fixedEmployee  String    @default("Ingen")
  notiOverride   Boolean   @default(false)
  active         Boolean   @default(true)
  pending        Boolean   @default(false) // afventende godkendelse (lead konverteret, pris ikke bekræftet endnu) — active er false imens
  tasks          TaskLine[]
  orders         Order[]
  weekSkips      SubscriptionWeekSkip[]
  createdAt      DateTime  @default(now())

  @@index([contactId])
}

model FixedPriceAgreement {
  id             Int       @id @default(autoincrement())
  displayNo      Int       @unique
  contact        Contact   @relation(fields: [contactId], references: [id])
  contactId      Int
  deliveryAddress String
  tasks          TaskLine[]
  orders         Order[]

  @@index([contactId])
}

model Order {
  id            Int       @id @default(autoincrement())
  contact       Contact   @relation(fields: [contactId], references: [id])
  contactId     Int
  deliveryAddress String
  plannedAt     DateTime  // leverings-DATO (gemt UTC-middag) — bevaret for bagudkompatibilitet
  startAt       DateTime? // præcist booket klokkeslæt inden for arbejdsdagen (07:00–15:00); null = ældre/dato-only ordre
  status        String    @default("Afventer levering")
  sourceType    String    // subscription | fixed | manual | online
  subscription  Subscription? @relation(fields: [subscriptionId], references: [id])
  subscriptionId Int?
  fixedPrice    FixedPriceAgreement? @relation(fields: [fixedPriceId], references: [id])
  fixedPriceId  Int?
  employee      User?     @relation(fields: [employeeId], references: [id])
  employeeId    Int?
  lockedFully   Boolean   @default(false)
  comment       String?
  addressNote   String?
  sourceWeek    DateTime? // rytme-ugens mandag ordren blev genereret FOR (dedup-nøgle — flytning ændrer den ikke; null for manuelle ordrer)
  // --- Fakturering via Dinero (sat i "Afslut ordre"-flowet) ---
  // invoiceDecision = det rå betalingsvalg fra CompleteOrderForm
  // ("Send faktura - ubetalt" | "Send faktura - betalt kontant" |
  //  "Send ikke faktura fra Fenster" | "Opret fakturakladde" |
  //  "Registrer på et senere tidspunkt"). Før i tiden blev valget kasseret.
  invoiceDecision       String?
  // dineroInvoiceGuid @unique er DB-værnet mod dobbeltfakturering: en ordre kan
  // kun bære ÉT Dinero-fakturaid. Sættes straks efter kladden er oprettet.
  dineroInvoiceGuid     String?  @unique
  dineroInvoiceTimeStamp String? // Dineros concurrency-token (roterer ved create/book/betaling) — kræves til book/email/payments og til genoptagelse efter fejl
  dineroInvoiceNumber   Int?     // tildeles juridisk ved bogføring (ikke ved kladde)
  dineroInvoiceStatus   String?  // simulated | Draft | Booked | Sent | Paid | Failed
  dineroPaymentGuid     String?  // betalings-guid ved "betalt kontant"
  dineroError           String?  // seneste fejldetalje (dansk), rydded ved succes
  invoicedAt            DateTime?
  tasks         TaskLine[]
  createdAt     DateTime  @default(now())

  @@unique([subscriptionId, sourceWeek]) // concurrency-værn: cron + manuel generering kan ikke dobbelt-oprette en uge
  @@index([contactId])
  @@index([subscriptionId])
  @@index([plannedAt])
}

// Tombstone: en bruger har SLETTET en abonnements-ordre for denne uge — natte-
// cronen må ikke genoplive den. Skrives af deleteOrder; regenerateFutureOrders
// (redigering) rører den ikke, da dén sletning er tilsigtet gen-generering.
model SubscriptionWeekSkip {
  id             Int          @id @default(autoincrement())
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  subscriptionId Int
  week           DateTime     // ugens mandag (UTC midnat)
  createdAt      DateTime     @default(now())

  @@unique([subscriptionId, week])
}

model DiscountCode {
  id         Int      @id @default(autoincrement())
  code       String
  percent    Int
  expiresAt  DateTime?
}

model HolidayWeek {
  id         Int      @id @default(autoincrement())
  startWeek  DateTime // Monday ISO date
  endWeek    DateTime
}

// Inbound sales lead from the public website form / webhook (POST /api/leads).
// Separate from Contact: a lead has few required fields and its own lifecycle
// (new → contacted → converted → rejected); converting creates a real Contact.
model Lead {
  id        Int      @id @default(autoincrement())
  company   Company  @relation(fields: [companyId], references: [id])
  companyId Int
  status    String   @default("new")     // new | contacted | converted | rejected
  name      String
  email     String?                       // stored lowercased/trimmed
  phone     String?                       // stored normalised (digits, +45 stripped)
  address   String?                       // free text as submitted
  message   String?
  source    String   @default("website")  // website | manual | partner | ...
  utm       String?                       // JSON blob string (schema has no Json type)
  payload   String?                       // JSON blob string fra tilbudsmotoren: {kundetype, services[], estimat}
  ip        String?                       // submitter IP for abuse forensics
  contact   Contact? @relation(fields: [contactId], references: [id])
  contactId Int?                          // set when converted to a customer
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, status])
  @@index([email])
  @@index([phone])
}

// Medarbejder-tidsregistrering ("Check ind / Check ud" — til/fra arbejde).
// Højst én åben registrering (checkOut = null) ad gangen per bruger håndhæves i
// server-action'en (app/actions/timesheet.ts) i en transaktion — portabelt uden
// partial unique index. checkIn/checkOut er UTC-tidsstempler.
model TimeEntry {
  id        Int       @id @default(autoincrement())
  user      User      @relation(fields: [userId], references: [id])
  userId    Int
  checkIn   DateTime  @default(now())
  checkOut  DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, checkIn])
}

// Dinero (Visma) regnskabsforbindelse — én pr. Company (single-tenant).
// Rummer resultatet af Visma Connect OAuth (authorization_code): den
// organisation brugeren valgte + roterende tokens. refreshTokenEnc er
// AES-256-GCM-krypteret (nøgle = DINERO_TOKEN_ENC_KEY). accessToken caches til
// det udløber (~1 t); refresh-tokenet ROTERER ved hver brug og opdateres i en
// række-lås (SELECT … FOR UPDATE), så to samtidige refreshes ikke laver et
// dobbelt-exchange, der ellers ugyldiggør HELE autorisationen hos Visma.
model DineroConnection {
  id             Int       @id @default(autoincrement())
  company        Company   @relation(fields: [companyId], references: [id])
  companyId      Int       @unique
  organizationId String    // Dinero firma-/organisations-ID (numerisk, gemt som streng — indgår i alle resource-URL'er)
  orgName        String?
  isPro          Boolean   @default(false) // API'et kræver Dinero Pro
  refreshTokenEnc String   // AES-256-GCM: "ivB64:tagB64:cipherB64"
  accessToken    String?   // cachet bearer-token (roterer)
  accessTokenExpiresAt DateTime?
  scopes         String?
  salesAccountNumber Int   @default(1000)  // kontonr. i Dinero kontoplan til bogføring af salg (afsendte fakturaer)
  cashAccountNumber  Int   @default(55040) // indbetalingskonto (kasse) til "betalt kontant"
  status         String    @default("connected") // connected | broken (kræver gen-forbindelse)
  connectedAt    DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}
