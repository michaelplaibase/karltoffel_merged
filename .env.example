# Copy to .env. The database is Neon (managed Postgres) for both dev and prod —
# it's remote, so no local Postgres install is needed. Get both strings from the
# Neon console: Project → Connect. DATABASE_URL is the POOLED string (host has
# "-pooler"); DIRECT_URL is the DIRECT string (no "-pooler"), used for migrations.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require&connect_timeout=15"
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/neondb?sslmode=require&connect_timeout=15"

# Secret used to sign session cookies (HMAC). MUST be 32+ random characters in
# production — the app refuses to boot without it (e.g. `openssl rand -hex 32`).
SESSION_SECRET="change-me"

# Shared secret for the nightly cron hitting /api/plan. Vercel sends it as
# `Authorization: Bearer <CRON_SECRET>`. Leave empty to disable cron access
# (logged-in users can still call the endpoint).
CRON_SECRET=""

# Shared secret for the public lead-intake webhook POST /api/leads (sent by the
# website's relay as the `x-karltoffel-secret` header). MUST be 32+ chars
# (e.g. `openssl rand -hex 32`) — the endpoint answers 503 until it is set.
# The SAME value must be configured on the website's Vercel project.
LEAD_WEBHOOK_SECRET=""

# Google Calendar-booking af 15-min opkalds-slots ved nye leads (lib/gcal.ts).
# Service-konto: Google Cloud Console → IAM → Service Accounts → opret + JSON-nøgle.
# GOOGLE_SA_EMAIL = client_email fra nøglefilen; GOOGLE_SA_KEY = private_key
# (behold \n-escapes når den sættes i Vercel). Del den fælles kalender med
# service-kontoens e-mail ("Foretag ændringer i begivenheder") og sæt kalenderens
# ID i GCAL_CALENDAR_ID. Uden disse dry-runner bookingen (lead gemmes stadig).
GOOGLE_SA_EMAIL=""
GOOGLE_SA_KEY=""
GCAL_CALENDAR_ID=""

# MCP-server for Karl (AI-operatøren) — POST /api/mcp (app/api/mcp/route.ts).
# KARL_MCP_TOKEN = 32+ tilfældige tegn (fx `openssl rand -hex 32`). Klienten
# sender det som `Authorization: Bearer <KARL_MCP_TOKEN>`. Tokenet valideres i
# konstant tid på HVERT kald. Fail-closed: er det ikke sat, svarer ruten 503 og
# kører ingen værktøjer.
KARL_MCP_TOKEN=""

# Dataforsyningen webservice-token til skråfoto-verifikationen på kundesiden
# (app/customers/[id] → components/SkraafotoCard). Bruges af CRM-proxyen
# (app/api/skraafoto/*) til STAC skråfoto-API'et og DHM-højdemodellen.
# VIGTIGT:
#  - Tokenet læses KUN serverside og når aldrig browseren (kaldene proxies
#    same-origin), så det behøver INGEN domæne/referer-binding — brug helst et
#    ubundet token, så det også virker på preview-deploys.
#  - Tokenet SKAL være godkendt til tjenesterne "Skråfoto" og "Danmarks
#    Højdemodel (DHM)" på dataforsyningen.dk → Administrer token. (DAWA er
#    tokenløst og kaldes direkte fra browseren.)
#  - Mangler tokenet: kortet viser "ikke konfigureret" (fail-closed).
DATAFORSYNINGEN_TOKEN=""

# E-mail-afsendelse via Resend (lib/email.ts) — kun "Send tilbud"-flowet sender.
# Dry-run som standard: intet sendes før BÅDE RESEND_API_KEY OG EMAIL_FROM er sat
# (og EMAIL_DRY_RUN ikke er "1"). Uden dem logges blot { simulated:true }.
# RESEND_API_KEY = API-nøgle fra Resend-dashboardet.
# EMAIL_FROM = en VERIFICERET Resend-afsender, f.eks. tilbud@karltoffel.dk —
# Resend afviser afsendelse fra et uverificeret domæne/afsender.
# EMAIL_REPLY_TO = valgfri reply-to-adresse.
# EMAIL_DRY_RUN = sæt til "1" for at tvinge dry-run selv når nøgle+afsender er sat.
RESEND_API_KEY=""
EMAIL_FROM=""
EMAIL_REPLY_TO=""
EMAIL_DRY_RUN=""

# Per-håndværker afsender for Karls booking-bekræftelser (send_confirmation).
# Sættes til et VERIFICERET Resend-domæne (fx "karltoffel.dk"). Så sendes
# bekræftelsen fra `<username>@<KARL_SENDER_DOMAIN>` med håndværkerens navn og
# reply-to = håndværkerens e-mail. Er den TOM, falder afsendelsen tilbage til
# EMAIL_FROM stemplet med håndværkerens navn + reply-to (ingen ægte per-bruger
# afsender). Alle brugernavne skal være gyldige postkasser under domænet.
KARL_SENDER_DOMAIN=""

# Dinero (Visma) regnskabsintegration — automatisk fakturering + bogføring fra
# "Afslut ordre" (lib/dinero.ts, /accounting).
# Auth = en Dinero Personal API Client (client_credentials, maskine-til-maskine):
# ingen browser-godkendelse, ingen redirect-URI, intet refresh-token. Access-tokenet
# hentes on-demand og caches i hukommelsen. Dry-run som standard (samme mønster som
# e-mail): der kaldes ALDRIG ud før BÅDE DINERO_CLIENT_ID OG DINERO_CLIENT_SECRET er
# sat (og DINERO_DRY_RUN ikke er "1"). Uden det logges { simulated:true }.
#  - DINERO_CLIENT_ID / DINERO_CLIENT_SECRET = client-id/secret for din Dinero
#    Personal API Client (oprettes i Dinero). Client-id'et har formen
#    "pcc_<orgId>_<navn>", fx pcc_639460_krltfl_aps — organisations-ID'et udledes
#    heraf automatisk.
#  - DINERO_DRY_RUN = sæt til "1" for at TVINGE dry-run selv når alt er konfigureret
#    (SKAL være "1" på preview/dev — ellers kan et preview-deploy bogføre ægte
#    fakturaer i produktions-organisationen).
#  - DINERO_ORG_ID = valgfri. Sæt kun hvis organisations-ID'et IKKE kan udledes af
#    client-id'et.
#  - DINERO_TOKEN_URL / DINERO_SCOPE / DINERO_CLIENT_AUTH = token-endpoint, scope og
#    client-auth-stil. Bekræftes mod Dinero API-klient-siden (curl-eksemplet) og med
#    "Test forbindelse" på /accounting.
#    To kendte varianter:
#      a) Dinero personal integration (pcc_-klient — mest sandsynligt):
#         DINERO_TOKEN_URL=https://authz.dinero.dk/dineroapi/oauth/token
#         DINERO_SCOPE="read write"           (client-auth = Basic udledes af host)
#      b) Visma Connect (isv_-klient):  standard —
#         https://connect.visma.com/connect/token, scope
#         "dineropublicapi:read dineropublicapi:write", credentials i body.
#    DINERO_CLIENT_AUTH override: "basic" (Authorization: Basic base64(id:secret))
#    eller "body" (id/secret i formularen). Tom = auto (basic for authz.dinero.dk).
#    Sæt DINERO_SCOPE="none" for helt at udelade scope.
# (DINERO_TOKEN_ENC_KEY og DINERO_REDIRECT_URI fra den tidligere OAuth-model bruges
#  IKKE længere og kan fjernes.)
DINERO_CLIENT_ID=""
DINERO_CLIENT_SECRET=""
DINERO_DRY_RUN=""
DINERO_ORG_ID=""
DINERO_TOKEN_URL=""
DINERO_SCOPE=""
DINERO_CLIENT_AUTH=""

# --- SITE (karltoffel.dk) serverless functions — sættes paa SITETS Vercel-projekt ---
# ANTHROPIC_API_KEY = vision-noegle til AI-vinduestaelling (site/api/windows.js).
# Dry-run som standard: uden noeglen returnerer endpointet {simulated:true} og
# tilbudsmotoren beholder sit standard-glasantal (samme moenster som e-mail ovenfor).
ANTHROPIC_API_KEY=""
